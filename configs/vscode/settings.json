  "whichkey.sortOrder": "alphabetically",
  // Copilot & Chat
  "chat.tools.terminal.autoApprove": {
    "npx": true,
    "cd": true,
    "ls": true,
    "git": true,
    "grep": true,
    "find": true,
    "npm install": true,
    "mv": true,
    "pnpm run -s typecheck": {
      "approve": true,
      "matchCommandLine": true
    },
    "true": true,
    "type": true,
    "pnpm build": {
      "approve": true,
      "matchCommandLine": true
    }
  },
  "chat.tools.urls.autoApprove": {},
  "chat.viewSessions.orientation": "stacked",
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  // Language-specific formatters
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true
    },
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[less]": {
    "editor.defaultFormatter": "vscode.css-language-features"
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  // Other
  "contextLink.pathType": "relative",
  "diffEditor.maxComputationTime": 0,
  "errorLens.delay": 50,
  "errorLens.delayMode": "debounce",
  "errorLens.enabled": true,
  "json.schemaDownload.enable": true,
  "path-intellisense.absolutePathToWorkspace": false,
  "path-intellisense.autoSlashAfterDirectory": false,
  "path-intellisense.mappings": {
    "$HOME": "/Users/devadathanmb/",
    "~": "/Users/devadathanmb/"
  },
  "path-intellisense.showHiddenFiles": false,
  "projectManager.any.baseFolders": [
    "~/repos/"
  ],
  "projectManager.any.excludeBaseFoldersFromResults": true,
  "projectManager.any.maxDepthRecursion": 1,
  "projectManager.hg.ignoredFolders": [
    "node_modules",
    "out",
    "typings",
    "test",
    ".haxelib"
  ],
  "projectManager.removeCurrentProjectFromList": true,
  "redhat.telemetry.enabled": false,
  "security.workspace.trust.untrustedFiles": "open",
  "sqlfluff.dialect": "postgres",
  "sqlfluff.suppressNotifications": true,
  "zenMode.centerLayout": false,
  "zenMode.hideLineNumbers": false
}