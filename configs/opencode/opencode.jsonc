{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-terra",
  "small_model": "opencode/deepseek-v4-flash-free",
  "plugin": [
    "opencode-minimax-easy-vision"
  ],
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,get_code_context_exa,crawling_exa",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": false
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "experimental": {
    "disable_paste_summary": true
  },
  "permission": {
    "bash": {
      "gh * create*": "deny",
      "gh * edit*": "deny",
      "git push *--force": "ask",
      "git push *--force *": "ask",
      "git push -f": "ask",
      "git push -f *": "ask",
      "git push * -f": "ask",
      "git push * -f *": "ask",
      "git push +*": "ask",
      "git push * +*": "ask",
      "git branch -D": "ask",
      "git branch -D *": "ask",
      "git push --delete *": "ask",
      "git push * --delete *": "ask",
      "git reset --hard": "ask",
      "git reset --hard *": "ask",
      "git clean -f *": "ask",
      "git clean -fd *": "ask",
      "git clean -fdx *": "ask",
      "rm *": "ask",
      "sudo *": "ask"
    }
  }
}
