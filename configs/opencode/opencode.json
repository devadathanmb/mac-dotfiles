{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
  ],
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    }
  },
  "provider": {
  },
  "experimental": {
    "disable_paste_summary": true
  },
  "permission": {
    "bash": {
      "gh * create*": "deny",
      "gh * edit*": "deny",
      "git push *--force": "ask",
      "git push *--force *": "ask",
      "git push -f": "ask",
      "git push -f *": "ask",
      "git push * -f": "ask",
      "git push * -f *": "ask",
      "git push +*": "ask",
      "git push * +*": "ask",
      "git branch -D": "ask",
      "git branch -D *": "ask",
      "git push --delete *": "ask",
      "git push * --delete *": "ask",
      "git reset --hard": "ask",
      "git reset --hard *": "ask",
      "git clean -f *": "ask",
      "git clean -fd *": "ask",
      "git clean -fdx *": "ask",
      "rm *": "ask",
      "sudo *": "ask"
    }
  }
}
