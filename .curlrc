# Follow redirects by default; most copied browser/API URLs bounce through auth, CDNs, or canonical hosts.
location

# Keep interactive downloads readable without curl's noisy default transfer meter.
progress-bar

# Treat HTTP 4xx/5xx as command failures while still printing the response body.
# This preserves useful JSON/API error payloads for debugging.
fail-with-body

# Fail fast when a host is unreachable instead of hanging terminal workflows.
connect-timeout = 10

# Cap total request time, including redirects and response download.
max-time = 60

# Ask servers for compressed responses and transparently decompress them.
# Saves bandwidth/time without changing the body curl prints.
compressed

# Print curl's own error message when a request fails.
show-error

# Prevent accidental infinite redirect loops.
max-redirs = 10

# Retry transient network/API failures that are common during ad-hoc backend debugging.
retry = 3
retry-delay = 1
retry-max-time = 20
retry-all-errors

# Prefer HTTP/2 when the server supports it; curl falls back when it cannot negotiate it.
http2

# Do not treat [], {}, etc. in copied API URLs as curl URL glob/range syntax.
globoff

# Abort stalled responses instead of waiting forever on a dead connection.
speed-time = 30
speed-limit = 1000
