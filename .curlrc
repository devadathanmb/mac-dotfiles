# Print status / method / timing / size to stderr after every request,
# keeping the body on stdout clean for piping.
write-out = "%{stderr}\n← %{http_code} %{method} %{url_effective}  (%{time_total}s, %{size_download} bytes, %{num_redirects} redirects)\n"

# Don't treat []{} in URLs as glob/range syntax.
globoff

# Show curl's error message even when output is silenced with -s.
show-error

# Give up on an unreachable host instead of hanging forever.
connect-timeout = 10
